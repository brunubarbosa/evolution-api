+// figurinha-fork patch: Promise.race timeout on every mutex acquisition.
+// Upstream rc.9 has no timeout — a stuck await locks the queue forever.
+// See PR #2151 (replaces with async-mutex; merged on master, unreleased).
+// We keep the original API; on timeout, the held slot rejects so the next
+// queued caller proceeds. The runaway code() promise is intentionally leaked
+// (still running, but no longer blocking the queue).
+const DEFAULT_MUTEX_TIMEOUT_MS = Number(process.env.BAILEYS_MUTEX_TIMEOUT_MS) || 60000;
+class MutexTimeoutError extends Error {
+    constructor(ms) {
+        super(`mutex code() did not resolve within ${ms}ms`);
+        this.name = 'MutexTimeoutError';
+    }
+}
