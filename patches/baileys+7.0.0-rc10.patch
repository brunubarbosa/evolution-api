+// [GDW] Outbound tracer hook — final breadcrumb before the encrypted
+// WhatsApp message stanza is flushed to the WS socket. The Evolution
+// wrapper consumes this via globalThis.__gdwOutboundTraceHook__ and
+// XADDs to the `outbound:trace` Redis Stream alongside L1/L2/L3. The
+// stderr line keeps the breadcrumb in `docker logs` if the in-process
+// hook is absent. Best-effort + bounded payload so a broken stderr
+// pipe is never propagated. Active whenever opts.traceId is set; no
+// env flag.
+function emitGdwTrace(traceId, subKind, extras) {
+    try {
+        const safe = {};
+        for (const [k, v] of Object.entries(extras)) {
+            if (v === undefined || v === null)
+                continue;
+            safe[k] = v;
+        }
+        const payload = {
+            gdw_trace: 1,
+            ts: new Date().toISOString(),
+            pid: process.pid,
+            layer: 'L4.relay',
+            trace_id: traceId,
+            sub_kind: subKind,
+            ...safe
+        };
+        process.stderr.write(JSON.stringify(payload) + '\n');
+        const hook = globalThis.__gdwOutboundTraceHook__;
+        if (typeof hook === 'function') {
+            try {
+                hook(payload);
+            }
+            catch {
+                /* hook errors must never break a send */
+            }
+        }
+    }
+    catch {
+        /* tracer must never break a send */
+    }
